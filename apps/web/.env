# SPXSwap .env — the gateway.uniswap.org surface is intentionally stubbed out.
# Any call to one of these stub URLs will hit 127.0.0.1:1 (discard-adjacent port)
# and fail immediately with ECONNREFUSED rather than firing a CORS preflight
# that takes 2+s to reject. Every hook that talked to the upstream backend has
# either been short-circuited to return empty data or rewired to call mainnet
# contracts directly via QuickNode.

# --- Stub URLs (unused, kept so nothing crashes if a missed hook still dereferences them) ---
REACT_APP_AMPLITUDE_PROXY_URL="http://127.0.0.1:9999/_stub/amplitude"
REACT_APP_AWS_API_ENDPOINT="http://127.0.0.1:9999/_stub/graphql"
REACT_APP_STATSIG_API_KEY="statsig_api_key_stub"
REACT_APP_STATSIG_PROXY_URL="http://127.0.0.1:9999/_stub/statsig"
REACT_APP_TEMP_API_URL="http://127.0.0.1:9999/_stub/temp"
REACT_APP_UNISWAP_GATEWAY_DNS="http://127.0.0.1:9999/_stub/gateway"
REACT_APP_TRADING_API_KEY="trading_api_key_stub"

# --- Config override env vars (read by packages/config/src/getConfig.web.ts) ---
# These flow into uniswapUrls.* in packages/uniswap/src/constants/urls.ts and
# force every *.gateway.uniswap.org path to the same 127.0.0.1:1 stub.
API_BASE_URL_OVERRIDE="http://127.0.0.1:9999/_stub/api"
API_BASE_URL_V2_OVERRIDE="http://127.0.0.1:9999/_stub/apiv2"
GRAPHQL_URL_OVERRIDE="http://127.0.0.1:9999/_stub/graphql"
TRADING_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/trading"
REACT_APP_TRADING_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/trading"
UNITAGS_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/unitags"
SCANTASTIC_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/scantastic"
FOR_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/for"
AMPLITUDE_PROXY_URL_OVERRIDE="http://127.0.0.1:9999/_stub/amplitude"
STATSIG_PROXY_URL_OVERRIDE="http://127.0.0.1:9999/_stub/statsig"
REACT_APP_LIQUIDITY_SERVICE_URL_OVERRIDE="http://127.0.0.1:9999/_stub/liquidity"
ENTRY_GATEWAY_API_URL_OVERRIDE="http://127.0.0.1:9999/_stub/entry-gateway"

# --- QuickNode (real — primary EVM RPC for quotes and swaps) ---
REACT_APP_QUICKNODE_ENDPOINT_NAME="tame-frequent-fog"
REACT_APP_QUICKNODE_ENDPOINT_TOKEN="774f0081965a0e9378059e0622c2a584fb8859f2"

# --- Moonpay (not used in V1 — leaving the bindings so FeatureFlagModal etc. don't crash) ---
REACT_APP_MOONPAY_API="https://api.moonpay.com"
REACT_APP_MOONPAY_LINK="https://us-central1-uniswap-mobile.cloudfunctions.net/signMoonpayLinkV2?platform=web&env=staging"
REACT_APP_MOONPAY_PUBLISHABLE_KEY="pk_test_DycfESRid31UaSxhI5yWKe1r5E5kKSz"

# --- WalletConnect (public project ID from upstream, replace with our own) ---
REACT_APP_WALLET_CONNECT_PROJECT_ID="c6c9bacd35afa3eb9e6cccf6d8464395"

REACT_APP_IS_UNISWAP_INTERFACE=true

# --- IPFS build settings ---
REACT_APP_SKIP_CSP=true
